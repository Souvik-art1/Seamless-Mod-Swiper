{
  "name": "seamless-mod-swiper",
  "version": "0.1.0",
  "description": "Electron + React desktop app for Tinder-style browsing of Cyberpunk 2077 mods from Nexus Mods",
  "main": "electron/main.js",
  "author": "Scrapybara / Capy",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:renderer": "vite build",
    "build": "vite build",
    "start": "electron .",
    "package": "electron-builder",
    "lint": "eslint . || true"
  },
  "dependencies": {
    "@react-spring/web": "^9.7.2",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "compromise": "^14.14.2",
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-tinder-card": "^1.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.scrapybara.seamless.mod.swiper",
    "productName": "Seamless Mod Swiper",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
